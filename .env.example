# DeepSeek API Key (required)
VITE_DEEPSEEK_API_KEY=sk-xxxxx

# Railway backend URL (production only — leave empty for local dev)
# Example: https://ario-api.railway.app
VITE_API_BASE_URL=

# Optional: Netease Cloud Music cookie (for full song URLs)
# Login at https://music.163.com, then copy the MUSIC_U cookie value
NCM_COOKIE=
